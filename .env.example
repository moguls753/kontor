# Copy to .env and fill in. Used by the full production stack (compose.yml) and
# by the standalone sidecar stacks (compose.scraper.yml / compose.easybank.yml).
#
# All three vars below are REQUIRED to bring up the full compose.yml stack.

# Rails master key (config/master.key) — required for the kontor service.
RAILS_MASTER_KEY=

# Shared secret between kontor and the tr-scraper sidecar (X-Sidecar-Token).
# Generate one with: openssl rand -hex 32
SCRAPER_SIDECAR_TOKEN=

# Shared secret between kontor and the easybank-scraper sidecar (X-Sidecar-Token).
# Generate one with: openssl rand -hex 32
# Rails (EasyBank::ScraperClient) reads EASYBANK_SIDECAR_URL too, which defaults
# to http://easybank-scraper:8000 — only override it if you rename the service
# or run the sidecar elsewhere.
EASYBANK_SIDECAR_TOKEN=
