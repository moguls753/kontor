# Copy to .env and fill in. Used by compose.scraper.yml.

# Shared secret between kontor and the tr-scraper sidecar (X-Sidecar-Token).
# Generate one with: openssl rand -hex 32
SCRAPER_SIDECAR_TOKEN=

# Shared secret between kontor and the easybank-scraper sidecar (X-Sidecar-Token).
# Used by compose.easybank.yml. Generate one with: openssl rand -hex 32
# Phase 2 (Rails EasyBank::ScraperClient) reads EASYBANK_SIDECAR_URL too, which
# defaults to http://easybank-scraper:8000 — only override it if you rename the
# service or run the sidecar elsewhere.
EASYBANK_SIDECAR_TOKEN=

# Rails master key (config/master.key) — only needed to run the kontor service.
RAILS_MASTER_KEY=
