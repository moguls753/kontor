# Copy to .env and fill in. Used by the full production stack (compose.yml) and
# by the standalone sidecar stacks (compose.scraper.yml / compose.easybank.yml /
# compose.paypal.yml).
#
# All vars below are REQUIRED to bring up compose.yml.
#
# FIRST-TIME SELF-HOSTING SETUP (see the README "Self-hosting" / docs/distribution.md):
#  1. Set the two *_SIDECAR_TOKEN values below FIRST — Compose needs them for EVERY
#     command (including the no-local-Ruby container credential path).
#  2. Generate your OWN Rails secrets (the repo ships none):
#       bin/rails credentials:edit     # config/master.key + credentials.yml.enc
#       bin/rails db:encryption:init   # prints 3 AR-encryption keys; paste them
#                                      # via a SECOND credentials:edit
#  3. Put the generated master key (contents of config/master.key) into
#     RAILS_MASTER_KEY below.

# Your Rails master key — decrypts YOUR credentials.yml.enc (secret_key_base +
# ActiveRecord encryption keys). Never the maintainer's key.
RAILS_MASTER_KEY=

# Shared secret between kontor and the tr-scraper sidecar (X-Sidecar-Token).
# Generate one with: openssl rand -hex 32
SCRAPER_SIDECAR_TOKEN=

# Shared secret between kontor and the easybank-scraper sidecar (X-Sidecar-Token).
# Generate one with: openssl rand -hex 32
# Rails (EasyBank::ScraperClient) reads EASYBANK_SIDECAR_URL too, which defaults
# to http://easybank-scraper:8000 — only override it if you rename the service
# or run the sidecar elsewhere.
EASYBANK_SIDECAR_TOKEN=

# Shared secret between kontor and the paypal-scraper sidecar (X-Sidecar-Token).
# Generate one with: openssl rand -hex 32
# Rails (Paypal::ScraperClient) reads PAYPAL_SIDECAR_URL too, which defaults to
# http://paypal-scraper:8000 — only override it if you rename the service or run
# the sidecar elsewhere. PayPal is MANUAL-SYNC-ONLY (no background job).
PAYPAL_SIDECAR_TOKEN=

# Pinned per-install browser fingerprint seed for the paypal-scraper (REQUIRED —
# the sidecar fails closed without it). CloakBrowser otherwise randomizes its
# --fingerprint each launch, which makes PayPal see a fresh device every login and
# re-fire the device-trust push step-up. Pick ANY stable integer and keep it
# constant for this install (e.g. 61803). Changing it later resets the trusted device.
PP_FINGERPRINT=61803
