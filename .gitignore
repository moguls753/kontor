# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files (but keep the committed template).
/.env*
!/.env.example

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore key files for decrypting credentials and more.
/config/*.key

# Not shipped: each self-hoster generates their own (see README / docs/distribution.md).
# A committed credentials.yml.enc is AES-encrypted; only your config/master.key
# (never in git) can read it — the standard Rails model, safe in a public repo.
# Keep master.key out of git and out of logs/CI output.
/config/credentials.yml.enc

# Private keys & certificates — never commit (Enable Banking app key, TLS certs).
*.pem
*.key

# HAR captures contain live session cookies + real account data — never commit.
*.har


# Vite Ruby
/public/vite*
node_modules
# Vite uses dotenv and suggests to ignore local-only env files. See
# https://vitejs.dev/guide/env-and-mode.html#env-files
*.local


# Throwaway TR WAF spike (browser venv + cookie jars) — never commit.
/scraper/spike/
